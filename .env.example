# LifeDesk CRM — Variables de entorno
# Copia este archivo como .env y llena los valores
# NUNCA subas el archivo .env a GitHub

# ── Supabase ──────────────────────────────────────────────────
# Los encuentras en: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Twilio (para más adelante) ────────────────────────────────
# VITE_TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxx
# VITE_TWILIO_AUTH_TOKEN=xxxxxxxxxxxx       ← NUNCA expongas esto en frontend
# El auth token solo va en el backend (Node.js), NUNCA en el browser
